# Магнат — переменные окружения.
# Скопируй в .env для локальной разработки (или задай в Railway → Variables).
# БЕЗ BOT_TOKEN сервер работает в DEV-режиме: авторизация заглушается одним
# локальным пользователем. Идеально для локального теста (соло против ботов
# вообще не требует сервера).

# От @BotFather (/newbot). Обязателен в проде.
BOT_TOKEN=

# Публичный HTTPS-адрес развёрнутого приложения (Railway выдаёт его),
# например https://magnat-production.up.railway.app
# Используется для вебхука Telegram и кнопки «Играть».
APP_URL=

# Username бота без @ (для инвайтов и диплинков комнат).
BOT_USERNAME=magnat_play_bot

# Секретный сегмент пути вебхука (любая случайная строка).
WEBHOOK_SECRET=change-me-to-something-random

# Подпись сессионных JWT (любая длинная случайная строка).
JWT_SECRET=change-me-to-a-long-random-string

# Расположение SQLite. На Railway укажи смонтированный том, например /data
DATA_DIR=./data

# Порт (Railway задаёт автоматически).
PORT=3000
